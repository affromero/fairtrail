# Fairtrail CLI — Live Price Chart View
Output packages/cli/demo/fairtrail-view.gif
Output packages/cli/demo/fairtrail-view.mp4

Set Shell "bash"
Set FontFamily "JetBrains Mono"
Set FontSize 15
Set Width 1400
Set Height 900
Set Padding 24
Set Theme "Catppuccin Mocha"
Set PlaybackSpeed 1
Set CursorBlink false

Type "./packages/cli/demo/ft --view cmmpf7lmv000106krkz364ajo"
Sleep 500ms
Enter
Sleep 5s

# Watch countdown tick
Sleep 8s

# Manual refresh
Type "r"
Sleep 4s

# Quit
Type "q"
Sleep 1s
